10  REM *** 4 EN RAYA - DOS JUGADORES ***
20  REM TABLERO: 7 COLUMNAS x 6 FILAS = 42 CELDAS
30  REM ALMACENADO EN UNA CADENA DE 42 CARACTERES
40  REM POSICION (F,C) = (F-1)*7 + C
50  REM "." = VACIA, "O" = JUGADOR 1, "X" = JUGADOR 2

100 REM *** INICIALIZAR ***
110 LET B$ = ".........................................."
120 LET TURNO = 1
130 LET GANADOR = 0

200 REM *** BUCLE PRINCIPAL ***
210 INK 7: PAPER 0: BRIGHT 0: CLS
220 GOSUB 2000
230 IF TURNO = 1 THEN LET FICHA$ = "O"
240 IF TURNO = 2 THEN LET FICHA$ = "X"
250 IF TURNO = 1 THEN PAPER 4
260 IF TURNO = 2 THEN PAPER 2
270 PRINT "JUGADOR "; TURNO; " ("; FICHA$; ") - ELIGE COLUMNA (1-7):"
280 PAPER 0
290 INPUT COL

300 REM *** VALIDAR COLUMNA ***
310 IF COL < 1 OR COL > 7 THEN GOTO 200

400 REM *** BUSCAR FILA LIBRE EN LA COLUMNA ***
410 LET FILA = 0
420 FOR F = 6 TO 1 STEP -1
430   LET POS = (F - 1) * 7 + COL
440   LET CELDA$ = B$(POS TO POS)
450   IF CELDA$ = "." AND FILA = 0 THEN LET FILA = F
460 NEXT F
470 IF FILA = 0 THEN GOTO 200

500 REM *** COLOCAR FICHA ***
510 LET POS = (FILA - 1) * 7 + COL
520 LET B$ = B$(TO POS - 1) + FICHA$ + B$(POS + 1 TO)

600 REM *** COMPROBAR VICTORIA ***
610 GOSUB 3000
620 IF GANADOR = 1 THEN GOTO 800

700 REM *** COMPROBAR EMPATE ***
710 LET EMPATE = 1
720 FOR C = 1 TO 7
730   LET CELDA$ = B$(C TO C)
740   IF CELDA$ = "." THEN LET EMPATE = 0
750 NEXT C
760 IF EMPATE = 1 THEN GOTO 850

770 REM *** CAMBIAR TURNO ***
780 IF TURNO = 1 THEN GOTO 795
790 LET TURNO = 1 : GOTO 200
795 LET TURNO = 2 : GOTO 200

800 REM *** VICTORIA ***
801 CLS
802 GOSUB 2000
803 BRIGHT 1
804 PRINT "*** JUGADOR "; TURNO; " GANA! ***"
805 BRIGHT 0
806 PRINT "PULSA ENTER PARA SALIR"
807 INPUT D$
808 STOP

850 REM *** EMPATE ***
851 CLS
852 GOSUB 2000
853 PRINT "*** ¡EMPATE! TABLERO LLENO ***"
854 PRINT "PULSA ENTER PARA SALIR"
855 INPUT D$
856 STOP

2000 REM *** SUBRUTINA: DIBUJAR TABLERO ***
2005 PAPER 0: INK 7: BRIGHT 0
2010 PRINT AT 2,0;"  1 2 3 4 5 6 7"
2020 PRINT " +-+-+-+-+-+-+-+"
2030 FOR F = 1 TO 6
2040   PRINT " |";
2050   FOR C = 1 TO 7
2060     LET POS = (F - 1) * 7 + C
2070     LET CELDA$ = B$(POS TO POS)
2080     IF CELDA$ = "O" THEN INK 4
2090     IF CELDA$ = "X" THEN INK 2
2100     IF CELDA$ = "." THEN INK 7
2110     PRINT CELDA$;
2120     INK 7
2130     PRINT "|";
2140   NEXT C
2150   PRINT
2160   PRINT " +-+-+-+-+-+-+-+"
2170 NEXT F
2180 PRINT
2190 RETURN

3000 REM *** SUBRUTINA: COMPROBAR VICTORIA ***
3010 LET GANADOR = 0

3020 REM --- HORIZONTAL (paso +1) ---
3030 FOR F = 1 TO 6
3040   FOR C = 1 TO 4
3050     LET P1 = (F-1)*7 + C
3060     LET P2 = P1 + 1
3070     LET P3 = P1 + 2
3080     LET P4 = P1 + 3
3090     IF B$(P1 TO P1) = FICHA$ AND B$(P2 TO P2) = FICHA$ AND B$(P3 TO P3) = FICHA$ AND B$(P4 TO P4) = FICHA$ THEN LET GANADOR = 1
3100   NEXT C
3110 NEXT F
3120 IF GANADOR = 1 THEN RETURN

3130 REM --- VERTICAL (paso +7) ---
3140 FOR F = 1 TO 3
3150   FOR C = 1 TO 7
3160     LET P1 = (F-1)*7 + C
3170     LET P2 = P1 + 7
3180     LET P3 = P1 + 14
3190     LET P4 = P1 + 21
3200     IF B$(P1 TO P1) = FICHA$ AND B$(P2 TO P2) = FICHA$ AND B$(P3 TO P3) = FICHA$ AND B$(P4 TO P4) = FICHA$ THEN LET GANADOR = 1
3210   NEXT C
3220 NEXT F
3230 IF GANADOR = 1 THEN RETURN

3240 REM --- DIAGONAL DESCENDENTE (paso +8) ---
3250 FOR F = 1 TO 3
3260   FOR C = 1 TO 4
3270     LET P1 = (F-1)*7 + C
3280     LET P2 = P1 + 8
3290     LET P3 = P1 + 16
3300     LET P4 = P1 + 24
3310     IF B$(P1 TO P1) = FICHA$ AND B$(P2 TO P2) = FICHA$ AND B$(P3 TO P3) = FICHA$ AND B$(P4 TO P4) = FICHA$ THEN LET GANADOR = 1
3320   NEXT C
3330 NEXT F
3340 IF GANADOR = 1 THEN RETURN

3350 REM --- DIAGONAL ASCENDENTE (paso +6) ---
3360 FOR F = 4 TO 6
3370   FOR C = 1 TO 4
3380     LET P1 = (F-1)*7 + C
3390     LET P2 = P1 - 6
3400     LET P3 = P1 - 12
3410     LET P4 = P1 - 18
3420     IF B$(P1 TO P1) = FICHA$ AND B$(P2 TO P2) = FICHA$ AND B$(P3 TO P3) = FICHA$ AND B$(P4 TO P4) = FICHA$ THEN LET GANADOR = 1
3430   NEXT C
3440 NEXT F
3450 RETURN
